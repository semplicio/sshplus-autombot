#!/bin/bash

set -e

REPO_USER="semplicio"
REPO_NAME="sshplus-autombot"
BRANCH="main"
BASE_URL="https://raw.githubusercontent.com/${REPO_USER}/${REPO_NAME}/${BRANCH}"

INSTALL_DIR="/usr/local/lib/sshplus"
BIN_DIR="/bin"
ETC_DIR="/etc/SSHPlus"
TMP_DIR="/tmp/sshplus-install"
LOG_FILE="/var/log/sshplus-install.log"
VERSION_FILE="${INSTALL_DIR}/versao"

export DEBIAN_FRONTEND=noninteractive

msg() {
  echo -e "\033[1;32m[INFO]\033[0m $1"
}

warn() {
  echo -e "\033[1;33m[AVISO]\033[0m $1"
}

err() {
  echo -e "\033[1;31m[ERRO]\033[0m $1"
}

require_root() {
  if [[ "$(id -u)" -ne 0 ]]; then
    err "Execute como root."
    exit 1
  fi
}

detect_arch() {
  ARCH="$(uname -m)"
  case "$ARCH" in
    aarch64|arm64)
      msg "Arquitetura ARM detectada: $ARCH"
      ;;
    *)
      err "Este instalador foi preparado para VPS ARM (aarch64/arm64). Detectado: $ARCH"
      exit 1
      ;;
  esac
}

prepare_dirs() {
  mkdir -p "$INSTALL_DIR" "$ETC_DIR" "$TMP_DIR"
  mkdir -p /root/sshplus-backup
  touch "$LOG_FILE"
  touch /var/log/sshplus.log
}

download_file() {
  local url="$1"
  local dest="$2"

  if ! curl -fsSL "$url" -o "$dest"; then
    err "Falha ao baixar: $url"
    exit 1
  fi
}

install_packages() {
  msg "Atualizando repositГіrios..."
  apt-get update -y >>"$LOG_FILE" 2>&1

  msg "Instalando dependГЄncias..."
  apt-get install -y \
    bc screen nano unzip lsof net-tools dos2unix nload jq curl wget figlet \
    python3 python3-pip socat at tar cron >>"$LOG_FILE" 2>&1 || {
      err "Falha ao instalar dependГЄncias. Veja: $LOG_FILE"
      exit 1
    }

  pip3 install speedtest-cli >>"$LOG_FILE" 2>&1 || true
}

prepare_base_files() {
  msg "Preparando base do sistema..."

  [[ -f /etc/IP ]] || curl -4 -fsSL ifconfig.me >/etc/IP 2>/dev/null || echo "0.0.0.0" >/etc/IP
  [[ -f /etc/autostart ]] || touch /etc/autostart
  [[ -f "${ETC_DIR}/Exp" ]] || echo "0" > "${ETC_DIR}/Exp"

  if [[ ! -f "$HOME/usuarios.db" ]]; then
    awk -F: '$3 >= 1000 { print $1 " 1" }' /etc/passwd | grep -v '^nobody' > "$HOME/usuarios.db" || true
  fi
}

install_remote_files() {
  msg "Baixando arquivos do repositГіrio..."

  download_file "${BASE_URL}/Install/versao" "${INSTALL_DIR}/versao"

  local modules_list="${TMP_DIR}/modules_arm.lst"
  download_file "${BASE_URL}/Install/modules_arm.lst" "$modules_list"

  while IFS= read -r module; do
    [[ -z "$module" ]] && continue
    [[ "$module" =~ ^# ]] && continue

    msg "Instalando mГіdulo: $module"
    download_file "${BASE_URL}/Modulos/${module}" "${BIN_DIR}/${module}"
    chmod 755 "${BIN_DIR}/${module}"
  done < "$modules_list"

  echo "/bin/menu" > /bin/h
  chmod 755 /bin/h
}

configure_firewall() {
  if command -v ufw >/dev/null 2>&1; then
    msg "Liberando portas comuns no firewall..."
    ufw allow 22/tcp >/dev/null 2>&1 || true
    ufw allow 80/tcp >/dev/null 2>&1 || true
    ufw allow 443/tcp >/dev/null 2>&1 || true
    ufw allow 8080/tcp >/dev/null 2>&1 || true
    ufw allow 8799/tcp >/dev/null 2>&1 || true
    ufw allow 3128/tcp >/dev/null 2>&1 || true
  fi
}

configure_cron() {
  msg "Configurando rotinas automГЎticas..."

  local cron_file="/etc/cron.d/sshplus-rotinas"
  cat > "$cron_file" <<EOF
*/1 * * * * root /bin/verifilimite >/dev/null 2>&1
*/5 * * * * root /bin/expcheck >/dev/null 2>&1
EOF

  chmod 644 "$cron_file"
  systemctl restart cron >/dev/null 2>&1 || service cron restart >/dev/null 2>&1 || true
}

show_summary() {
  clear
  echo -e "\033[1;32mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
  echo -e "\033[1;37m         SSHPLUS AutomBot ARM instalado       \033[0m"
  echo -e "\033[1;32mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
  echo -e "\033[1;33mComando principal:\033[0m menu"
  echo -e "\033[1;33mAtalho:\033[0m h"
  echo -e "\033[1;33mLog de instalaГ§ГЈo:\033[0m ${LOG_FILE}"
  echo -e "\033[1;33mVersГЈo local:\033[0m $(head -n 1 "${VERSION_FILE}" 2>/dev/null || echo 'indefinida')"
  echo
}

main() {
  clear
  require_root
  detect_arch
  prepare_dirs
  install_packages
  prepare_base_files
  install_remote_files
  main() {
  clear
  require_root
  detect_arch
  prepare_dirs
  install_packages
  prepare_base_files
  install_remote_files
  /bin/loggerapi "INSTALL" "Instalacao/atualizacao executada com sucesso"
  configure_firewall
  configure_cron
  show_summary
}
  configure_firewall
  configure_cron
  show_summary
}

main "$@"
