#!/bin/bash

set -e

REPO_USER="SEU_USUARIO_GITHUB"
REPO_NAME="SEU_REPOSITORIO"
BRANCH="main"
BASE_URL="https://raw.githubusercontent.com/${REPO_USER}/${REPO_NAME}/${BRANCH}"

INSTALL_DIR="/usr/local/lib/sshplus"
BIN_DIR="/bin"
TMP_DIR="/tmp/sshplus-install"
VERSION_FILE="${INSTALL_DIR}/versao"
LOG_FILE="/var/log/sshplus-install.log"

export DEBIAN_FRONTEND=noninteractive

msg() {
  echo -e "\033[1;32m[INFO]\033[0m $1"
}

warn() {
  echo -e "\033[1;33m[AVISO]\033[0m $1"
}

err() {
  echo -e "\033[1;31m[ERRO]\033[0m $1"
}

require_root() {
  if [[ "$(id -u)" -ne 0 ]]; then
    err "Execute como root."
    exit 1
  fi
}

detect_arch() {
  ARCH="$(uname -m)"
  if [[ "$ARCH" != "aarch64" && "$ARCH" != "arm64" ]]; then
    err "Este instalador ARM exige arquitetura aarch64/arm64. Detectado: $ARCH"
    exit 1
  fi
}

prepare_dirs() {
  mkdir -p "$INSTALL_DIR" "$TMP_DIR"
  touch "$LOG_FILE"
}

check_dependencies() {
  msg "Atualizando índices de pacotes..."
  apt-get update -y >>"$LOG_FILE" 2>&1

  msg "Instalando dependências básicas..."
  apt-get install -y \
    curl wget unzip tar jq bc screen nano lsof net-tools dos2unix nload figlet \
    python3 python3-pip socat ca-certificates >>"$LOG_FILE" 2>&1
}

download_file() {
  local url="$1"
  local dest="$2"

  if ! curl -fsSL "$url" -o "$dest"; then
    err "Falha ao baixar: $url"
    exit 1
  fi
}

install_core_files() {
  msg "Baixando arquivos principais..."

  download_file "${BASE_URL}/Install/versao" "${INSTALL_DIR}/versao"
  download_file "${BASE_URL}/Modulos/menu" "${BIN_DIR}/menu"
  download_file "${BASE_URL}/Modulos/verifatt" "${BIN_DIR}/verifatt"
  download_file "${BASE_URL}/Modulos/attscript" "${BIN_DIR}/attscript"

  chmod 755 "${BIN_DIR}/menu" "${BIN_DIR}/verifatt" "${BIN_DIR}/attscript"
}

create_shortcuts() {
  echo "/bin/menu" > /bin/h
  chmod 755 /bin/h
}

configure_firewall() {
  if command -v ufw >/dev/null 2>&1; then
    msg "Liberando portas básicas no UFW..."
    ufw allow 22/tcp >/dev/null 2>&1 || true
    ufw allow 80/tcp >/dev/null 2>&1 || true
    ufw allow 443/tcp >/dev/null 2>&1 || true
    ufw allow 8080/tcp >/dev/null 2>&1 || true
  fi
}

finish_install() {
  msg "Instalação base concluída."
  echo
  echo "Comando principal: menu"
  echo "Log de instalação: $LOG_FILE"
}

main() {
  clear
  require_root
  detect_arch
  prepare_dirs
  check_dependencies
  install_core_files
  create_shortcuts
  configure_firewall
  finish_install
}

main "$@"
