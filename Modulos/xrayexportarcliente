#!/bin/bash

EXPORT_DIR="/root/sshplus-export/clientes-xray"
TMP_FILE="/tmp/xray_cliente_export.txt"

mkdir -p "$EXPORT_DIR"

clear
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "      EXPORTAR CONFIGURAÇÃO XRAY"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo

if [[ ! -x /bin/xraygerarconfig ]]; then
  echo "Módulo /bin/xraygerarconfig não encontrado."
  echo
  read -p "Enter para voltar..."
  exit 1
fi

read -p "Nome do arquivo de exportação (ex: cliente1): " export_name
[[ -z "$export_name" ]] && echo "Nome inválido." && read -p "Enter para voltar..." && exit 1

/bin/xraygerarconfig | tee "$TMP_FILE" >/dev/null

OUT_FILE="${EXPORT_DIR}/${export_name}.txt"
cp "$TMP_FILE" "$OUT_FILE"
rm -f "$TMP_FILE"

echo
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Exportação concluída"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Arquivo: $OUT_FILE"
echo
/bin/loggerapi "XRAY_CLIENT_EXPORT" "arquivo=${OUT_FILE}"
read -p "Enter para voltar..."