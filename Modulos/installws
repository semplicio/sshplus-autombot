#!/bin/bash

WS_DIR="/usr/local/wsproxy"
WS_CONF="$WS_DIR/ws.conf"
WS_START="$WS_DIR/start.sh"
WS_SERVICE="/etc/systemd/system/wsproxy.service"
WSTUNNEL_BIN="/usr/local/bin/wstunnel"

verde(){ echo -e "\033[1;32m$1\033[0m"; }
amarelo(){ echo -e "\033[1;33m$1\033[0m"; }
vermelho(){ echo -e "\033[1;31m$1\033[0m"; }

pause(){
echo
read -p "Enter para voltar..."
}

require_root(){
if [[ "$(id -u)" != "0" ]]; then
vermelho "Execute como root"
exit 1
fi
}

install_deps(){

apt-get update -y >/dev/null 2>&1
apt-get install -y curl wget dos2unix >/dev/null 2>&1

}

detect_arch(){

ARCH=$(uname -m)

case "$ARCH" in
aarch64|arm64)
echo arm64
;;
x86_64|amd64)
echo amd64
;;
*)
vermelho "Arquitetura não suportada: $ARCH"
exit 1
;;
esac

}

install_wstunnel(){

ARCH=$(detect_arch)

if [[ "$ARCH" == "arm64" ]]; then
URL="https://github.com/erebe/wstunnel/releases/latest/download/wstunnel_linux_arm64"
else
URL="https://github.com/erebe/wstunnel/releases/latest/download/wstunnel_linux_amd64"
fi

verde "Instalando wstunnel..."

wget -qO "$WSTUNNEL_BIN" "$URL"

chmod +x "$WSTUNNEL_BIN"

}

create_dirs(){

mkdir -p "$WS_DIR"

}

create_config(){

read -p "Porta WebSocket [8080]: " WS_PORT
read -p "Bind [0.0.0.0]: " WS_BIND
read -p "Destino SSH [127.0.0.1:22]: " WS_TARGET

WS_PORT=${WS_PORT:-8080}
WS_BIND=${WS_BIND:-0.0.0.0}
WS_TARGET=${WS_TARGET:-127.0.0.1:22}

cat > "$WS_CONF" <<EOF
WS_PORT=$WS_PORT
WS_BIND=$WS_BIND
WS_TARGET=$WS_TARGET
EOF

}

create_start(){

cat > "$WS_START" <<'EOF'
#!/usr/bin/env bash

source /usr/local/wsproxy/ws.conf

exec /usr/local/bin/wstunnel -s ${WS_BIND}:${WS_PORT} -t ${WS_TARGET}
EOF

chmod +x "$WS_START"

}

create_service(){

cat > "$WS_SERVICE" <<EOF
[Unit]
Description=SSH WebSocket Proxy
After=network.target

[Service]
ExecStart=$WS_START
Restart=always

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable wsproxy.service >/dev/null 2>&1

}

start_service(){

systemctl restart wsproxy.service

}

show_status(){

clear
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "   STATUS WEBSOCKET SSH"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo

cat "$WS_CONF"

echo
systemctl status wsproxy.service --no-pager

}

main(){

clear
require_root

verde "Instalador WebSocket SSH"

install_deps
create_dirs
install_wstunnel
create_config
create_start
create_service
start_service
show_status

pause

}

main