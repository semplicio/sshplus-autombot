#!/bin/bash

set -e

WS_DIR="/usr/local/wsproxy"
WS_CONF="${WS_DIR}/ws.conf"
WS_START="${WS_DIR}/start.sh"
WS_SERVICE="/etc/systemd/system/wsproxy.service"
WS_PORT_DEFAULT="8080"
WS_BIND_DEFAULT="0.0.0.0"
WS_TARGET_DEFAULT="127.0.0.1:22"
WSTUNNEL_BIN="/usr/local/bin/wstunnel"

verde() { echo -e "\033[1;32m$1\033[0m"; }
amarelo() { echo -e "\033[1;33m$1\033[0m"; }
vermelho() { echo -e "\033[1;31m$1\033[0m"; }
azul() { echo -e "\033[1;34m$1\033[0m"; }

pause() {
  echo
  read -rp "Enter para voltar..." _
}

require_root() {
  if [[ "$(id -u)" -ne 0 ]]; then
    vermelho "Execute como root."
    exit 1
  fi
}

detect_arch() {
  local arch
  arch="$(uname -m)"
  case "$arch" in
    aarch64|arm64)
      echo "arm64"
      ;;
    x86_64|amd64)
      echo "amd64"
      ;;
    *)
      vermelho "Arquitetura não suportada para instalação automática do wstunnel: $arch"
      exit 1
      ;;
  esac
}

install_dependencies() {
  apt-get update -y >/dev/null 2>&1 || true
  apt-get install -y curl wget dos2unix >/dev/null 2>&1 || {
    vermelho "Falha ao instalar dependências básicas."
    exit 1
  }
}

install_wstunnel() {
  local arch url tmp_file
  arch="$(detect_arch)"

  case "$arch" in
    arm64)
      url="https://github.com/erebe/wstunnel/releases/latest/download/wstunnel_linux_arm64"
      ;;
    amd64)
      url="https://github.com/erebe/wstunnel/releases/latest/download/wstunnel_linux_amd64"
      ;;
  esac

  azul "Instalando wstunnel para arquitetura: $arch"
  tmp_file="/tmp/wstunnel.$$"

  if ! curl -fsSL "$url" -o "$tmp_file"; then
    vermelho "Falha ao baixar o binário do wstunnel."
    exit 1
  fi

  mv "$tmp_file" "$WSTUNNEL_BIN"
  chmod +x "$WSTUNNEL_BIN"

  if ! "$WSTUNNEL_BIN" --help >/dev/null 2>&1; then
    vermelho "O binário do wstunnel foi instalado, mas falhou no teste."
    exit 1
  fi

  verde "wstunnel instalado com sucesso em $WSTUNNEL_BIN"
}

create_dirs() {
  mkdir -p "$WS_DIR"
}

create_ws_conf() {
  local ws_port ws_bind ws_target

  echo
  read -rp "Porta do WebSocket [${WS_PORT_DEFAULT}]: " ws_port
  read -rp "Bind do WebSocket [${WS_BIND_DEFAULT}]: " ws_bind
  read -rp "Destino do SSH [${WS_TARGET_DEFAULT}]: " ws_target

  ws_port="${ws_port:-$WS_PORT_DEFAULT}"
  ws_bind="${ws_bind:-$WS_BIND_DEFAULT}"
  ws_target="${ws_target:-$WS_TARGET_DEFAULT}"

  cat > "$WS_CONF" <<EOF
WS_PORT=${ws_port}
WS_BIND=${ws_bind}
WS_TARGET=${ws_target}
EOF

  chmod 644 "$WS_CONF"
  verde "Configuração salva em $WS_CONF"
}

create_start_script() {
  cat > "$WS_START" <<'EOF'
#!/usr/bin/env bash
set -e

source /usr/local/wsproxy/ws.conf

WSTUNNEL_BIN="/usr/local/bin/wstunnel"

if [ ! -x "$WSTUNNEL_BIN" ]; then
  echo "wstunnel não encontrado em $WSTUNNEL_BIN"
  exit 127
fi

exec "$WSTUNNEL_BIN" -s "${WS_BIND}:${WS_PORT}" -t "${WS_TARGET}"
EOF

  dos2unix "$WS_START" >/dev/null 2>&1 || true
  chmod +x "$WS_START"
  verde "Script de inicialização criado em $WS_START"
}

create_service() {
  cat > "$WS_SERVICE" <<EOF
[Unit]
Description=SSH WebSocket Proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=${WS_START}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

  chmod 644 "$WS_SERVICE"
  systemctl daemon-reload
  systemctl enable wsproxy.service >/dev/null 2>&1 || true
  verde "Serviço systemd criado em $WS_SERVICE"
}

stop_old_service_if_needed() {
  systemctl stop wsproxy.service >/dev/null 2>&1 || true
}

start_service() {
  systemctl restart wsproxy.service
}

show_status() {
  clear
  azul "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "         STATUS WEBSOCKET SSH"
  azul "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  if [[ -f "$WS_CONF" ]]; then
    cat "$WS_CONF"
  else
    echo "Arquivo de configuração não encontrado."
  fi

  echo
  systemctl status wsproxy.service --no-pager -l || true
  echo
}

validate_runtime() {
  if ! bash -n "$WS_START"; then
    vermelho "Erro de sintaxe no start.sh"
    exit 1
  fi

  if ! "$WSTUNNEL_BIN" --help >/dev/null 2>&1; then
    vermelho "Falha ao validar o wstunnel."
    exit 1
  fi
}

show_logs() {
  echo
  azul "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "LOGS DO SERVIÇO"
  azul "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  journalctl -u wsproxy.service -n 20 --no-pager || true
}

main() {
  clear
  require_root
  install_dependencies
  create_dirs
  install_wstunnel
  create_ws_conf
  create_start_script
  create_service
  validate_runtime
  stop_old_service_if_needed
  start_service
  show_status
  show_logs
  pause
}

main "$@"