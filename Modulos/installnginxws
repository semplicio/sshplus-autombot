#!/bin/bash

NGINX_SITE="/etc/nginx/sites-available/sshplus"
NGINX_LINK="/etc/nginx/sites-enabled/sshplus"
META_FILE="/etc/sshplus-nginx-meta.conf"

verde(){ echo -e "\033[1;32m$1\033[0m"; }
amarelo(){ echo -e "\033[1;33m$1\033[0m"; }
vermelho(){ echo -e "\033[1;31m$1\033[0m"; }
azul(){ echo -e "\033[1;34m$1\033[0m"; }

pause() {
  echo
  read -p "Enter para voltar..." _
}

require_root() {
  if [[ "$(id -u)" != "0" ]]; then
    vermelho "Execute como root."
    exit 1
  fi
}

log_action() {
  if [[ -x /bin/loggerapi ]]; then
    /bin/loggerapi "$1" "$2" >/dev/null 2>&1 || true
  fi
}

cleanup_old_nginx() {
  systemctl stop nginx >/dev/null 2>&1 || true
  pkill -f 'nginx: master process' >/dev/null 2>&1 || true
  pkill -f 'nginx: worker process' >/dev/null 2>&1 || true
  sleep 2
}

stop_apache_if_exists() {
  systemctl stop apache2 >/dev/null 2>&1 || true
  systemctl disable apache2 >/dev/null 2>&1 || true
  pkill -f apache2 >/dev/null 2>&1 || true
  sleep 1
}

show_port_80_usage() {
  ss -lntp | grep ':80 ' || true
}

check_port_80_free() {
  if ss -lntp | grep -q ':80 '; then
    return 1
  fi
  return 0
}

check_domain_points_here() {
  local domain="$1"
  local public_ip dns_ip

  public_ip="$(curl -4 -fsSL ifconfig.me 2>/dev/null || true)"
  dns_ip="$(getent ahostsv4 "$domain" 2>/dev/null | awk '{print $1}' | head -n1)"

  [[ -z "$public_ip" ]] && return 0
  [[ -z "$dns_ip" ]] && return 1
  [[ "$public_ip" == "$dns_ip" ]]
}

install_packages() {
  apt update -y
  apt install -y nginx certbot python3-certbot-nginx curl
}

write_meta_file() {
  local domain="$1"
  local ws_port="$2"
  local xray_ws_port="$3"
  local xray_ws_path="$4"
  local xray_grpc_port="$5"
  local grpc_service="$6"

  cat > "$META_FILE" <<EOF
DOMAIN=${domain}
WS_PORT=${ws_port}
XRAY_WS_PORT=${xray_ws_port}
XRAY_WS_PATH=${xray_ws_path}
XRAY_GRPC_PORT=${xray_grpc_port}
XRAY_GRPC_SERVICE=${grpc_service}
XRAY_GRPC_PATH=/${grpc_service}/Tun
EOF
}

write_http_config() {
  local domain="$1"
  local ws_port="$2"
  local xray_ws_port="$3"
  local xray_ws_path="$4"

  cat > "$NGINX_SITE" <<EOF
server {
    listen 80;
    server_name ${domain};

    location / {
        return 200 'SSHPLUS AutomBot ARM';
        add_header Content-Type text/plain;
    }

    location /ws {
        proxy_redirect off;
        proxy_pass http://127.0.0.1:${ws_port};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
    }

    location ${xray_ws_path} {
        proxy_redirect off;
        proxy_pass http://127.0.0.1:${xray_ws_port};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
    }
}
EOF
}

write_https_config() {
  local domain="$1"
  local ws_port="$2"
  local xray_ws_port="$3"
  local xray_ws_path="$4"
  local xray_grpc_port="$5"
  local grpc_service="$6"

  cat > "$NGINX_SITE" <<EOF
server {
    listen 80;
    server_name ${domain};
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name ${domain};

    ssl_certificate /etc/letsencrypt/live/${domain}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${domain}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    location / {
        return 200 'SSHPLUS AutomBot ARM TLS';
        add_header Content-Type text/plain;
    }

    location /ws {
        proxy_redirect off;
        proxy_pass http://127.0.0.1:${ws_port};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
    }

    location ${xray_ws_path} {
        proxy_redirect off;
        proxy_pass http://127.0.0.1:${xray_ws_port};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
    }

    location /${grpc_service}/Tun {
        grpc_set_header X-Real-IP \$remote_addr;
        grpc_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        grpc_pass grpc://127.0.0.1:${xray_grpc_port};
    }
}
EOF
}

prepare_nginx_site() {
  rm -f /etc/nginx/sites-enabled/default
  rm -f /etc/nginx/sites-available/default
  ln -sf "$NGINX_SITE" "$NGINX_LINK"
}

start_nginx_safely() {
  cleanup_old_nginx
  stop_apache_if_exists

  if ! check_port_80_free; then
    vermelho "A porta 80 está em uso antes de iniciar o Nginx."
    show_port_80_usage
    return 1
  fi

  nginx -t || return 1
  systemctl enable nginx >/dev/null 2>&1 || true
  systemctl start nginx || return 1

  sleep 1

  if ! systemctl is-active --quiet nginx; then
    vermelho "O Nginx não permaneceu ativo."
    systemctl status nginx -l --no-pager || true
    return 1
  fi

  return 0
}

install_nginx_ws() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "   NGINX AVANÇADO + TLS + WS + gRPC"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  read -p "Domínio apontado para esta VPS: " domain
  [[ -z "$domain" ]] && echo "Domínio inválido." && pause && return

  read -p "Porta interna do WebSocket SSH [8080]: " ws_port
  ws_port="${ws_port:-8080}"

  read -p "Porta interna do Xray WS [10000]: " xray_ws_port
  xray_ws_port="${xray_ws_port:-10000}"

  read -p "Path do Xray WS [/vmess]: " xray_ws_path
  xray_ws_path="${xray_ws_path:-/vmess}"

  read -p "Porta interna do Xray gRPC [20000]: " xray_grpc_port
  xray_grpc_port="${xray_grpc_port:-20000}"

  read -p "ServiceName do gRPC [grpc]: " grpc_service
  grpc_service="${grpc_service:-grpc}"

  [[ ! "$ws_port" =~ ^[0-9]+$ ]] && echo "Porta WS inválida." && pause && return
  [[ ! "$xray_ws_port" =~ ^[0-9]+$ ]] && echo "Porta Xray WS inválida." && pause && return
  [[ ! "$xray_grpc_port" =~ ^[0-9]+$ ]] && echo "Porta Xray gRPC inválida." && pause && return

  install_packages

  write_meta_file "$domain" "$ws_port" "$xray_ws_port" "$xray_ws_path" "$xray_grpc_port" "$grpc_service"
  write_http_config "$domain" "$ws_port" "$xray_ws_port" "$xray_ws_path"
  prepare_nginx_site

  if ! check_domain_points_here "$domain"; then
    amarelo "Aviso: o domínio pode não estar apontando para esta VPS."
    amarelo "Confira DNS antes de continuar com o SSL."
    echo
  fi

  if ! start_nginx_safely; then
    echo
    vermelho "Falha ao iniciar o Nginx com segurança."
    vermelho "Verifique a porta 80 e os logs do serviço."
    echo
    show_port_80_usage
    pause
    return
  fi

  if ! certbot --nginx -d "$domain" --non-interactive --register-unsafely-without-email --agree-tos --redirect; then
    echo
    vermelho "Falha ao gerar certificado SSL."
    vermelho "Verifique domínio, DNS e porta 80 liberada."
    echo
    systemctl status nginx -l --no-pager || true
    show_port_80_usage
    pause
    return
  fi

  write_https_config "$domain" "$ws_port" "$xray_ws_port" "$xray_ws_path" "$xray_grpc_port" "$grpc_service"

  nginx -t || {
    echo "Erro na configuração final do Nginx."
    pause
    return
  }

  cleanup_old_nginx
  systemctl restart nginx || {
    vermelho "Falha ao reiniciar o Nginx na configuração final."
    systemctl status nginx -l --no-pager || true
    pause
    return
  }

  log_action "NGINX_TLS_INSTALL" "dominio=${domain} ws_port=${ws_port} xray_ws_port=${xray_ws_port} xray_ws_path=${xray_ws_path} grpc_port=${xray_grpc_port} grpc_service=${grpc_service}"

  echo
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "Nginx avançado configurado com sucesso"
  echo "Domínio      : ${domain}"
  echo "WS SSH       : https://${domain}/ws"
  echo "Xray WS      : https://${domain}${xray_ws_path}"
  echo "Xray gRPC    : https://${domain}/${grpc_service}/Tun"
  echo "ServiceName  : ${grpc_service}"
  echo "HTTPS/TLS    : 443"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo
  pause
}

status_nginx_ws() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "     STATUS NGINX AVANÇADO + TLS"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  [[ -f "$META_FILE" ]] && echo "Metadados:" && cat "$META_FILE" && echo
  [[ -f "$NGINX_SITE" ]] && echo "Configuração:" && cat "$NGINX_SITE" && echo

  systemctl status nginx -l --no-pager || true
  echo
  echo "Portas em uso:"
  ss -lntp | grep -E ':80 |:443 ' || true
  echo
  pause
}

restart_nginx_ws() {
  cleanup_old_nginx
  systemctl restart nginx || {
    vermelho "Falha ao reiniciar o Nginx."
    systemctl status nginx -l --no-pager || true
    pause
    return
  }

  log_action "NGINX_TLS_RESTART" "nginx reiniciado"
  echo
  echo "Nginx reiniciado."
  echo
  pause
}

renew_ssl() {
  certbot renew --dry-run
  echo
  pause
}

remove_nginx_ws() {
  read -p "Confirma remover configuração Nginx/TLS? [s/N]: " confirm
  [[ "$confirm" != "s" && "$confirm" != "S" ]] && return

  rm -f "$NGINX_LINK"
  rm -f "$NGINX_SITE"
  rm -f "$META_FILE"

  cleanup_old_nginx
  systemctl restart nginx >/dev/null 2>&1 || true

  log_action "NGINX_TLS_REMOVE" "configuracao removida"

  echo
  echo "Configuração removida."
  echo
  pause
}

while true; do
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "    GERENCIAR NGINX AVANÇADO + TLS"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo " [1] Instalar / Reconfigurar"
  echo " [2] Ver status"
  echo " [3] Reiniciar"
  echo " [4] Testar renovação SSL"
  echo " [5] Remover configuração"
  echo " [0] Voltar"
  echo
  read -p "Escolha uma opção: " op
  case "$op" in
    1) install_nginx_ws ;;
    2) status_nginx_ws ;;
    3) restart_nginx_ws ;;
    4) renew_ssl ;;
    5) remove_nginx_ws ;;
    0) exit 0 ;;
    *) echo "Opção inválida."; sleep 1 ;;
  esac
done