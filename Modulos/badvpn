#!/bin/bash

SERVICE_TEMPLATE="/etc/systemd/system/autombot-badvpn@.service"
SYSCTL_FILE="/etc/sysctl.d/99-autombot-network.conf"
CONFIG_DIR="/etc/autombot"
CONFIG_FILE="${CONFIG_DIR}/badvpn.conf"
PROJECT_ROOT="/usr/local/lib/sshplus"
BUILD_LOG="/tmp/autombot-badvpn-build.log"

verde() { echo -e "\033[1;32m$1\033[0m"; }
amarelo() { echo -e "\033[1;33m$1\033[0m"; }
vermelho() { echo -e "\033[1;31m$1\033[0m"; }
azul() { echo -e "\033[1;34m$1\033[0m"; }
branco() { echo -e "\033[1;37m$1\033[0m"; }
roxo() { echo -e "\033[0;35m$1\033[0m"; }

pause() {
  echo
  read -p "Enter para voltar..." _
}

header() {
  clear
  roxo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  branco "                 BADVPN AUTOMBOT                  "
  roxo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo
}

log() {
  echo "[$(date '+%F %T')] $*" >> "$BUILD_LOG"
}

check_root() {
  if [[ "$EUID" -ne 0 ]]; then
    vermelho "Este módulo precisa ser executado como root."
    exit 1
  fi
}

ensure_config() {
  mkdir -p "$CONFIG_DIR"
  if [[ ! -f "$CONFIG_FILE" ]]; then
    cat > "$CONFIG_FILE" <<EOF
BADVPN_BIND=127.0.0.1
BADVPN_MAX_CLIENTS=1024
BADVPN_MAX_CONN_PER_CLIENT=64
EOF
  fi
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
}

save_config_value() {
  local key="$1"
  local value="$2"

  mkdir -p "$CONFIG_DIR"
  touch "$CONFIG_FILE"

  if grep -q "^${key}=" "$CONFIG_FILE" 2>/dev/null; then
    sed -i "s|^${key}=.*|${key}=${value}|" "$CONFIG_FILE"
  else
    echo "${key}=${value}" >> "$CONFIG_FILE"
  fi
}

detect_default_iface() {
  ip route 2>/dev/null | awk '/default/ {print $5; exit}'
}

apply_network_tuning() {
  cat > "$SYSCTL_FILE" <<'EOF'
net.ipv4.ip_forward=1
net.core.rmem_max=16777216
net.core.wmem_max=16777216
net.core.netdev_max_backlog=5000
net.ipv4.udp_rmem_min=16384
net.ipv4.udp_wmem_min=16384
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_fin_timeout=15
net.ipv4.tcp_keepalive_time=600
net.ipv4.tcp_mtu_probing=1
EOF

  sysctl --system >>"$BUILD_LOG" 2>&1 || true
}

ensure_nat() {
  local iface
  iface="$(detect_default_iface)"

  if [[ -z "$iface" ]]; then
    vermelho "Não foi possível detectar a interface principal de rede."
    return 1
  fi

  if ! iptables -t nat -C POSTROUTING -o "$iface" -j MASQUERADE 2>/dev/null; then
    iptables -t nat -A POSTROUTING -o "$iface" -j MASQUERADE >>"$BUILD_LOG" 2>&1
  fi

  if ! iptables -C FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT 2>/dev/null; then
    iptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT >>"$BUILD_LOG" 2>&1
  fi

  if ! iptables -C FORWARD -j ACCEPT 2>/dev/null; then
    iptables -A FORWARD -j ACCEPT >>"$BUILD_LOG" 2>&1
  fi

  if command -v netfilter-persistent >/dev/null 2>&1; then
    netfilter-persistent save >>"$BUILD_LOG" 2>&1 || true
  elif [[ -d /etc/iptables || ! -e /etc/iptables ]]; then
    mkdir -p /etc/iptables
    iptables-save > /etc/iptables/rules.v4 2>>"$BUILD_LOG" || true
  fi

  return 0
}

allow_badvpn_port() {
  local porta="$1"
  ensure_config

  if [[ "${BADVPN_BIND}" == "0.0.0.0" ]]; then
    if command -v ufw >/dev/null 2>&1; then
      ufw allow "${porta}/tcp" >>"$BUILD_LOG" 2>&1 || true
    fi
  fi
}

remove_badvpn_port() {
  local porta="$1"
  ensure_config

  if [[ "${BADVPN_BIND}" == "0.0.0.0" ]]; then
    if command -v ufw >/dev/null 2>&1; then
      ufw delete allow "${porta}/tcp" >>"$BUILD_LOG" 2>&1 || true
    fi
  fi
}

is_valid_port() {
  local porta="$1"
  [[ "$porta" =~ ^[0-9]+$ ]] || return 1
  (( porta >= 1 && porta <= 65535 )) || return 1
  return 0
}

install_deps_for_build() {
  export DEBIAN_FRONTEND=noninteractive
  log "Instalando dependências de build"
  apt-get update -y >>"$BUILD_LOG" 2>&1 || return 1
  apt-get install -y git gcc g++ make cmake build-essential wget curl ca-certificates >>"$BUILD_LOG" 2>&1 || return 1
  return 0
}

copy_project_binary() {
  local arch source_file

  arch="$(uname -m)"
  case "$arch" in
    aarch64|arm64|armv7l|armv8l)
      source_file="${PROJECT_ROOT}/ARM/badvpn-udpgw"
      ;;
    x86_64|amd64)
      source_file="${PROJECT_ROOT}/bin/badvpn-udpgw"
      ;;
    *)
      source_file="${PROJECT_ROOT}/bin/badvpn-udpgw"
      ;;
  esac

  log "Tentando usar binário do projeto: $source_file"

  if [[ -f "$source_file" ]]; then
    cp -f "$source_file" /bin/badvpn-udpgw >>"$BUILD_LOG" 2>&1
    chmod +x /bin/badvpn-udpgw >>"$BUILD_LOG" 2>&1
    /bin/badvpn-udpgw --help >>"$BUILD_LOG" 2>&1 || true
    return 0
  fi

  return 1
}

build_badvpn_from_source() {
  local build_dir="/tmp/autombot-badvpn-build"

  branco "Compilando badvpn-udpgw automaticamente..."
  log "Iniciando compilação automática"

  install_deps_for_build || return 1

  rm -rf "$build_dir"
  git clone https://github.com/ambrop72/badvpn.git "$build_dir" >>"$BUILD_LOG" 2>&1 || return 1
  cd "$build_dir" || return 1

  if [[ -x ./compile-udpgw.sh || -f ./compile-udpgw.sh ]]; then
    chmod +x ./compile-udpgw.sh >>"$BUILD_LOG" 2>&1
    ./compile-udpgw.sh >>"$BUILD_LOG" 2>&1 || true

    if [[ -f ./badvpn-udpgw ]]; then
      cp -f ./badvpn-udpgw /bin/badvpn-udpgw >>"$BUILD_LOG" 2>&1
      chmod +x /bin/badvpn-udpgw >>"$BUILD_LOG" 2>&1
      return 0
    fi
  fi

  mkdir -p build
  cd build || return 1
  cmake .. -DBUILD_NOTHING_BY_DEFAULT=1 -DBUILD_UDPGW=1 >>"$BUILD_LOG" 2>&1 || return 1
  make -j1 >>"$BUILD_LOG" 2>&1 || return 1

  if [[ -f udpgw/badvpn-udpgw ]]; then
    cp -f udpgw/badvpn-udpgw /bin/badvpn-udpgw >>"$BUILD_LOG" 2>&1
    chmod +x /bin/badvpn-udpgw >>"$BUILD_LOG" 2>&1
    return 0
  fi

  if [[ -f ./badvpn-udpgw ]]; then
    cp -f ./badvpn-udpgw /bin/badvpn-udpgw >>"$BUILD_LOG" 2>&1
    chmod +x /bin/badvpn-udpgw >>"$BUILD_LOG" 2>&1
    return 0
  fi

  return 1
}

ensure_badvpn_binary() {
  : > "$BUILD_LOG"

  if [[ -x /bin/badvpn-udpgw ]]; then
    log "Usando /bin/badvpn-udpgw"
    return 0
  fi

  if [[ -x /usr/bin/badvpn-udpgw ]]; then
    log "Usando /usr/bin/badvpn-udpgw"
    ln -sf /usr/bin/badvpn-udpgw /bin/badvpn-udpgw >>"$BUILD_LOG" 2>&1
    chmod +x /bin/badvpn-udpgw >>"$BUILD_LOG" 2>&1
    return 0
  fi

  copy_project_binary && return 0
  build_badvpn_from_source && return 0

  return 1
}

create_service_template() {
  ensure_config

  cat > "$SERVICE_TEMPLATE" <<EOF
[Unit]
Description=AutomBot BadVPN UDPGW on port %i
After=network.target

[Service]
Type=simple
ExecStart=/bin/badvpn-udpgw --listen-addr ${BADVPN_BIND}:%i --max-clients ${BADVPN_MAX_CLIENTS} --max-connections-for-client ${BADVPN_MAX_CONN_PER_CLIENT}
Restart=always
RestartSec=2
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
EOF

  systemctl daemon-reload >>"$BUILD_LOG" 2>&1
}

start_port() {
  local porta="$1"

  if ! is_valid_port "$porta"; then
    vermelho "Porta inválida: $porta"
    return 1
  fi

  if ! ensure_badvpn_binary; then
    vermelho "Falha ao instalar/compilar o badvpn-udpgw."
    echo
    echo "Log detalhado:"
    echo "  $BUILD_LOG"
    return 1
  fi

  create_service_template
  apply_network_tuning
  ensure_nat || return 1
  allow_badvpn_port "$porta"

  systemctl enable --now "autombot-badvpn@${porta}" >>"$BUILD_LOG" 2>&1

  if systemctl is-active --quiet "autombot-badvpn@${porta}"; then
    verde "BadVPN ativo na porta TCP $porta."
    return 0
  fi

  vermelho "Falha ao ativar BadVPN na porta $porta."
  echo
  echo "Log detalhado:"
  echo "  $BUILD_LOG"
  return 1
}

stop_port() {
  local porta="$1"

  if ! is_valid_port "$porta"; then
    vermelho "Porta inválida: $porta"
    return 1
  fi

  systemctl disable --now "autombot-badvpn@${porta}" >/dev/null 2>&1 || true
  remove_badvpn_port "$porta"

  verde "BadVPN parado na porta TCP $porta."
  return 0
}

list_ports() {
  local found=0

  echo
  branco "SERVIÇOS BADVPN"
  azul "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  while read -r unit load active sub desc; do
    [[ -z "$unit" ]] && continue
    echo " $unit  |  $active"
    found=1
  done < <(systemctl list-units --type=service --all --no-legend 2>/dev/null | grep 'autombot-badvpn@')

  if [[ "$found" -eq 0 ]]; then
    amarelo "Nenhuma porta BadVPN cadastrada."
  fi

  echo
  branco "PORTAS TCP EM ESCUTA"
  azul "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  ss -lntp 2>/dev/null | grep badvpn || amarelo "Nenhuma porta TCP BadVPN em escuta."
  echo
}

show_status() {
  header
  ensure_config

  if ensure_badvpn_binary; then
    verde "Binário badvpn-udpgw: OK"
  else
    vermelho "Binário badvpn-udpgw: AUSENTE"
    echo "Log: $BUILD_LOG"
  fi

  local iface
  iface="$(detect_default_iface)"
  echo -e "\033[1;33mInterface principal:\033[0m ${iface:-desconhecida}"
  echo -e "\033[1;33mIP Forward:\033[0m $(cat /proc/sys/net/ipv4/ip_forward 2>/dev/null)"
  echo -e "\033[1;33mBind atual:\033[0m ${BADVPN_BIND}"
  echo -e "\033[1;33mMax clients:\033[0m ${BADVPN_MAX_CLIENTS}"
  echo -e "\033[1;33mMax conexões por cliente:\033[0m ${BADVPN_MAX_CONN_PER_CLIENT}"

  echo
  list_ports
  pause
}

install_base() {
  header
  branco "Preparando base do BadVPN..."

  if ! ensure_badvpn_binary; then
    vermelho "Não foi possível obter o badvpn-udpgw."
    echo
    echo "O módulo tentou:"
    echo "  1) usar /bin/badvpn-udpgw"
    echo "  2) usar /usr/bin/badvpn-udpgw"
    echo "  3) usar o binário do projeto"
    echo "  4) compilar automaticamente do source"
    echo
    echo "Log detalhado:"
    echo "  $BUILD_LOG"
    pause
    return 1
  fi

  ensure_config
  create_service_template
  apply_network_tuning
  ensure_nat || {
    pause
    return 1
  }

  verde "Base configurada com sucesso."
  pause
}

activate_default_ports() {
  header
  branco "Ativando portas padrão 7300 e 7000..."
  echo

  start_port 7300
  start_port 7000

  echo
  list_ports
  pause
}

open_custom_port() {
  header
  local porta

  read -p "Informe a porta TCP que deseja abrir: " porta

  if ! is_valid_port "$porta"; then
    vermelho "Porta inválida."
    pause
    return
  fi

  echo
  start_port "$porta"
  pause
}

stop_custom_port() {
  header
  local porta

  read -p "Informe a porta TCP que deseja parar: " porta

  if ! is_valid_port "$porta"; then
    vermelho "Porta inválida."
    pause
    return
  fi

  echo
  stop_port "$porta"
  pause
}

set_bind_mode() {
  header
  echo " [1] Somente local (127.0.0.1) - mais seguro"
  echo " [2] Público (0.0.0.0) - acesso externo"
  echo
  read -p "Escolha o modo de bind: " opt

  case "$opt" in
    1)
      save_config_value "BADVPN_BIND" "127.0.0.1"
      verde "Bind ajustado para 127.0.0.1"
      ;;
    2)
      save_config_value "BADVPN_BIND" "0.0.0.0"
      verde "Bind ajustado para 0.0.0.0"
      ;;
    *)
      vermelho "Opção inválida."
      ;;
  esac

  systemctl daemon-reload >/dev/null 2>&1 || true
  pause
}

set_limits() {
  header
  local clients conns

  read -p "Max clients [atual 1024]: " clients
  read -p "Max conexões por cliente [atual 64]: " conns

  [[ -z "$clients" ]] && clients="1024"
  [[ -z "$conns" ]] && conns="64"

  if ! [[ "$clients" =~ ^[0-9]+$ ]]; then
    vermelho "Max clients inválido."
    pause
    return
  fi

  if ! [[ "$conns" =~ ^[0-9]+$ ]]; then
    vermelho "Max conexões por cliente inválido."
    pause
    return
  fi

  save_config_value "BADVPN_MAX_CLIENTS" "$clients"
  save_config_value "BADVPN_MAX_CONN_PER_CLIENT" "$conns"

  verde "Limites atualizados."
  pause
}

restart_all_badvpn() {
  header
  branco "Reiniciando todas as instâncias do BadVPN..."
  systemctl daemon-reload >/dev/null 2>&1 || true
  systemctl list-units --type=service --all --no-legend 2>/dev/null \
    | awk '/autombot-badvpn@[0-9]+\.service/ {print $1}' \
    | while read -r unit; do
        systemctl restart "$unit" >/dev/null 2>&1 || true
      done
  verde "Instâncias reiniciadas."
  pause
}

view_logs() {
  header
  local porta

  read -p "Informe a porta do serviço para ver logs: " porta

  if ! is_valid_port "$porta"; then
    vermelho "Porta inválida."
    pause
    return
  fi

  echo
  journalctl -u "autombot-badvpn@${porta}" -n 50 --no-pager 2>/dev/null || vermelho "Sem logs para esta porta."
  echo
  echo "Log de build:"
  echo "  $BUILD_LOG"
  pause
}

show_build_log() {
  header
  if [[ -f "$BUILD_LOG" ]]; then
    tail -n 120 "$BUILD_LOG"
  else
    amarelo "Log de build ainda não foi gerado."
  fi
  pause
}

badvpn_menu() {
  check_root

  while true; do
    ensure_config
    header
    echo " [1] Preparar base do BadVPN"
    echo " [2] Ativar portas padrão (7300 e 7000)"
    echo " [3] Abrir nova porta TCP"
    echo " [4] Parar porta TCP"
    echo " [5] Listar portas ativas"
    echo " [6] Ver status geral"
    echo " [7] Ver logs de uma porta"
    echo " [8] Alterar modo de bind (${BADVPN_BIND})"
    echo " [9] Ajustar limites (${BADVPN_MAX_CLIENTS}/${BADVPN_MAX_CONN_PER_CLIENT})"
    echo " [10] Reiniciar instâncias BadVPN"
    echo " [11] Ver log de build"
    echo " [0] Voltar"
    echo
    read -p "Escolha uma opção: " opcao

    case "$opcao" in
      1) install_base ;;
      2) activate_default_ports ;;
      3) open_custom_port ;;
      4) stop_custom_port ;;
      5) header; list_ports; pause ;;
      6) show_status ;;
      7) view_logs ;;
      8) set_bind_mode ;;
      9) set_limits ;;
      10) restart_all_badvpn ;;
      11) show_build_log ;;
      0) exit 0 ;;
      *) vermelho "Opção inválida."; sleep 1 ;;
    esac
  done
}

badvpn_menu