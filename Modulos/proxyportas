#!/bin/bash

BASE_DIR="/etc/SSHPlus/proxy-ports"
RUNNER="/usr/local/lib/sshplus/proxyport-runner.sh"

verde(){ echo -e "\033[1;32m$1\033[0m"; }
amarelo(){ echo -e "\033[1;33m$1\033[0m"; }
vermelho(){ echo -e "\033[1;31m$1\033[0m"; }
azul(){ echo -e "\033[1;34m$1\033[0m"; }

pause() {
  echo
  read -p "Enter para voltar..." _
}

require_root() {
  if [[ "$(id -u)" != "0" ]]; then
    vermelho "Execute como root."
    exit 1
  fi
}

log_action() {
  if [[ -x /bin/loggerapi ]]; then
    /bin/loggerapi "$1" "$2" >/dev/null 2>&1 || true
  fi
}

ensure_base() {
  mkdir -p "$BASE_DIR"
  mkdir -p /usr/local/lib/sshplus

  apt-get update -y >/dev/null 2>&1 || true
  apt-get install -y socat openssl netcat-openbsd curl >/dev/null 2>&1 || {
    vermelho "Falha ao instalar dependências."
    exit 1
  }

  cat > "$RUNNER" <<'EOF'
#!/bin/bash

set -euo pipefail

CONF_FILE="$1"

if [[ ! -f "$CONF_FILE" ]]; then
  echo "Arquivo de configuração não encontrado: $CONF_FILE"
  exit 1
fi

source "$CONF_FILE"

MODE="${MODE:-ssh-only}"
LISTEN_PORT="${LISTEN_PORT:-8080}"
TARGET_HOST="${TARGET_HOST:-127.0.0.1}"
TARGET_PORT="${TARGET_PORT:-22}"
CERT_FILE="${CERT_FILE:-}"
RESPONSE_TEXT="${RESPONSE_TEXT:-SSHPLUS-AUTOMBOT}"

case "$MODE" in
  ssh-only|http)
    exec socat TCP-LISTEN:"${LISTEN_PORT}",reuseaddr,fork TCP:"${TARGET_HOST}":"${TARGET_PORT}"
    ;;
  https)
    if [[ -z "$CERT_FILE" || ! -f "$CERT_FILE" ]]; then
      echo "Certificado não encontrado para modo https: $CERT_FILE"
      exit 1
    fi
    exec socat OPENSSL-LISTEN:"${LISTEN_PORT}",reuseaddr,fork,cert="${CERT_FILE}",verify=0 TCP:"${TARGET_HOST}":"${TARGET_PORT}"
    ;;
  *)
    echo "Modo inválido: $MODE"
    exit 1
    ;;
esac
EOF

  chmod +x "$RUNNER"
}

open_firewall_port() {
  local port="$1"

  iptables -C INPUT -p tcp --dport "$port" -j ACCEPT >/dev/null 2>&1 || \
    iptables -I INPUT -p tcp --dport "$port" -j ACCEPT

  if command -v ufw >/dev/null 2>&1; then
    ufw allow "${port}/tcp" >/dev/null 2>&1 || true
    ufw reload >/dev/null 2>&1 || true
  fi
}

remove_firewall_port() {
  local port="$1"

  while iptables -C INPUT -p tcp --dport "$port" -j ACCEPT >/dev/null 2>&1; do
    iptables -D INPUT -p tcp --dport "$port" -j ACCEPT >/dev/null 2>&1 || break
  done

  if command -v ufw >/dev/null 2>&1; then
    ufw delete allow "${port}/tcp" >/dev/null 2>&1 || true
    ufw reload >/dev/null 2>&1 || true
  fi
}

validate_https_cert() {
  local cert_file="$1"

  [[ -z "$cert_file" ]] && return 1
  [[ ! -f "$cert_file" ]] && return 1

  openssl x509 -in "$cert_file" -noout >/dev/null 2>&1
}

create_service() {
  local port="$1"
  local conf_file="$2"
  local service="/etc/systemd/system/sshplus-proxy-${port}.service"

  cat > "$service" <<EOF
[Unit]
Description=SSHPLUS Proxy Port ${port}
After=network.target

[Service]
Type=simple
ExecStart=${RUNNER} ${conf_file}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

  chmod 644 "$service"
  systemctl daemon-reload
  systemctl enable "sshplus-proxy-${port}.service" >/dev/null 2>&1 || true
}

write_config() {
  local conf_file="$1"
  local mode="$2"
  local port="$3"
  local target_host="$4"
  local target_port="$5"
  local cert_file="$6"
  local response_text="$7"

  cat > "$conf_file" <<EOF
MODE=${mode}
LISTEN_PORT=${port}
TARGET_HOST=${target_host}
TARGET_PORT=${target_port}
CERT_FILE=${cert_file}
RESPONSE_TEXT=${response_text}
EOF
}

show_connection_summary() {
  local port="$1"
  local mode="$2"
  local target_host="$3"
  local target_port="$4"

  echo
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "RESUMO DA PORTA"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "Porta externa : ${port}"
  echo "Modo          : ${mode}"
  echo "Destino       : ${target_host}:${target_port}"
  echo
  echo "Exemplos:"
  echo "Host/IP       : SEU_IP_OU_DOMINIO"
  echo "Porta         : ${port}"
  echo "Tipo          : ${mode}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo
}

test_proxy_port() {
  local port="$1"

  echo
  echo "[TESTE LOCAL DA PORTA ${port}]"
  ss -lntp | grep ":${port}" || true
  echo
  timeout 5 bash -c "echo > /dev/tcp/127.0.0.1/${port}" >/dev/null 2>&1 \
    && verde "Porta ${port} aceitando conexão local." \
    || amarelo "Não foi possível confirmar conexão local na porta ${port}."
  echo
}

install_proxy_port() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      ABRIR PORTA DE CONEXÃO"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  local port mode mode_opt target_host target_port cert_file conf_file response_text

  read -p "Porta para abrir [8080]: " port
  port="${port:-8080}"

  if [[ ! "$port" =~ ^[0-9]+$ ]]; then
    vermelho "Porta inválida."
    pause
    return
  fi

  echo
  echo "[1] ssh-only"
  echo "[2] http"
  echo "[3] https"
  echo
  read -p "Escolha o modo [1]: " mode_opt
  mode_opt="${mode_opt:-1}"

  case "$mode_opt" in
    1) mode="ssh-only" ;;
    2) mode="http" ;;
    3) mode="https" ;;
    *) vermelho "Modo inválido."; pause; return ;;
  esac

  read -p "Host de destino [127.0.0.1]: " target_host
  target_host="${target_host:-127.0.0.1}"

  read -p "Porta de destino [22]: " target_port
  target_port="${target_port:-22}"

  read -p "Texto de referência/resposta [SSHPLUS-AUTOMBOT]: " response_text
  response_text="${response_text:-SSHPLUS-AUTOMBOT}"

  cert_file=""
  if [[ "$mode" == "https" ]]; then
    read -p "Caminho do certificado PEM [/etc/letsencrypt/live/vpn.autombot.com.br/fullchain.pem]: " cert_file
    cert_file="${cert_file:-/etc/letsencrypt/live/vpn.autombot.com.br/fullchain.pem}"

    if ! validate_https_cert "$cert_file"; then
      vermelho "Certificado inválido ou não encontrado: $cert_file"
      pause
      return
    fi
  fi

  conf_file="${BASE_DIR}/${port}.conf"

  write_config "$conf_file" "$mode" "$port" "$target_host" "$target_port" "$cert_file" "$response_text"
  create_service "$port" "$conf_file"
  open_firewall_port "$port"

  if ! systemctl restart "sshplus-proxy-${port}.service"; then
    vermelho "Falha ao iniciar serviço da porta ${port}."
    systemctl status "sshplus-proxy-${port}.service" -l --no-pager || true
    pause
    return
  fi

  log_action "PROXY_PORT_INSTALL" "port=${port} mode=${mode} target=${target_host}:${target_port}"

  verde "Porta ${port} criada com sucesso."
  test_proxy_port "$port"
  show_connection_summary "$port" "$mode" "$target_host" "$target_port"
  pause
}

list_proxy_ports() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      PORTAS DE CONEXÃO ATIVAS"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  ls "$BASE_DIR"/*.conf >/dev/null 2>&1 || {
    echo "Nenhuma porta configurada."
    pause
    return
  }

  for file in "$BASE_DIR"/*.conf; do
    echo "Arquivo: $file"
    cat "$file"
    echo
  done

  echo "[SERVIÇOS]"
  systemctl list-units --type=service --all | grep 'sshplus-proxy-' || true
  echo
  pause
}

restart_proxy_port() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      REINICIAR PORTA"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  read -p "Porta para reiniciar: " port
  [[ -z "$port" ]] && return

  systemctl restart "sshplus-proxy-${port}.service" || {
    vermelho "Falha ao reiniciar."
    systemctl status "sshplus-proxy-${port}.service" -l --no-pager || true
    pause
    return
  }

  verde "Porta ${port} reiniciada."
  test_proxy_port "$port"
  pause
}

remove_proxy_port() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      REMOVER PORTA"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  read -p "Porta para remover: " port
  [[ -z "$port" ]] && return

  systemctl stop "sshplus-proxy-${port}.service" >/dev/null 2>&1 || true
  systemctl disable "sshplus-proxy-${port}.service" >/dev/null 2>&1 || true
  rm -f "/etc/systemd/system/sshplus-proxy-${port}.service"
  rm -f "${BASE_DIR}/${port}.conf"
  remove_firewall_port "$port"
  systemctl daemon-reload

  log_action "PROXY_PORT_REMOVE" "port=${port}"

  verde "Porta ${port} removida."
  pause
}

logs_proxy_port() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      LOGS DA PORTA"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  read -p "Porta para ver logs: " port
  [[ -z "$port" ]] && return

  journalctl -u "sshplus-proxy-${port}.service" -n 50 --no-pager || true
  pause
}

status_proxy_port() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      STATUS DA PORTA"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  read -p "Porta para verificar: " port
  [[ -z "$port" ]] && return

  if [[ -f "${BASE_DIR}/${port}.conf" ]]; then
    echo "[CONFIG]"
    cat "${BASE_DIR}/${port}.conf"
    echo
  fi

  systemctl status "sshplus-proxy-${port}.service" -l --no-pager || true
  echo
  ss -lntp | grep ":${port}" || true
  echo
  pause
}

require_root
ensure_base

while true; do
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "     GERENCIAR PORTAS DE CONEXÃO"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo " [1] Abrir nova porta"
  echo " [2] Listar portas"
  echo " [3] Ver status da porta"
  echo " [4] Reiniciar porta"
  echo " [5] Remover porta"
  echo " [6] Ver logs da porta"
  echo " [0] Voltar"
  echo
  read -p "Escolha uma opção: " op

  case "$op" in
    1) install_proxy_port ;;
    2) list_proxy_ports ;;
    3) status_proxy_port ;;
    4) restart_proxy_port ;;
    5) remove_proxy_port ;;
    6) logs_proxy_port ;;
    0) exit 0 ;;
    *) echo "Opção inválida."; sleep 1 ;;
  esac
done