#!/bin/bash

set -u

SQUID_CONF="/etc/squid/squid.conf"
SQUID_BACKUP="/etc/squid/squid.conf.bak"
PORTS_FILE="/etc/SSHPlus/squid-ports.list"
META_FILE="/etc/sshplus-proxyhttpmulti-meta.conf"
DEBUG_LOG="/tmp/proxyhttpmulti-debug.log"

verde(){ echo -e "\033[1;32m$1\033[0m"; }
amarelo(){ echo -e "\033[1;33m$1\033[0m"; }
vermelho(){ echo -e "\033[1;31m$1\033[0m"; }

log() {
  echo "[$(date '+%F %T')] $*" >> "$DEBUG_LOG"
}

pause() {
  echo
  read -p "Enter para voltar..." _
}

fail() {
  vermelho "$1"
  echo
  echo "Log: $DEBUG_LOG"
  pause
  return 1
}

require_root() {
  if [[ "$(id -u)" != "0" ]]; then
    vermelho "Execute como root."
    exit 1
  fi
}

log_action() {
  if [[ -x /bin/loggerapi ]]; then
    /bin/loggerapi "$1" "$2" >/dev/null 2>&1 || true
  fi
}

ensure_base() {
  mkdir -p /etc/SSHPlus
  touch "$PORTS_FILE"

  if [[ -f "$SQUID_CONF" && ! -f "$SQUID_BACKUP" ]]; then
    cp "$SQUID_CONF" "$SQUID_BACKUP" >>"$DEBUG_LOG" 2>&1 || true
  fi
}

install_packages() {
  log "Instalando dependências"
  apt-get update -y >>"$DEBUG_LOG" 2>&1 || return 1
  apt-get install -y squid curl iptables ufw dos2unix >>"$DEBUG_LOG" 2>&1 || return 1
  return 0
}

normalize_ports_file() {
  sort -n "$PORTS_FILE" | uniq | grep -E '^[0-9]+$' > "${PORTS_FILE}.tmp" 2>/dev/null || true
  mv -f "${PORTS_FILE}.tmp" "$PORTS_FILE"
}

port_exists() {
  local port="$1"
  grep -qx "$port" "$PORTS_FILE"
}

add_port_to_list() {
  local port="$1"
  port_exists "$port" || echo "$port" >> "$PORTS_FILE"
  normalize_ports_file
}

remove_port_from_list() {
  local port="$1"
  grep -vx "$port" "$PORTS_FILE" > "${PORTS_FILE}.tmp" 2>/dev/null || true
  mv -f "${PORTS_FILE}.tmp" "$PORTS_FILE"
  normalize_ports_file
}

open_firewall_port() {
  local port="$1"

  iptables -C INPUT -p tcp --dport "$port" -j ACCEPT >/dev/null 2>&1 || \
    iptables -I INPUT -p tcp --dport "$port" -j ACCEPT >>"$DEBUG_LOG" 2>&1 || true

  if command -v ufw >/dev/null 2>&1; then
    ufw allow "${port}/tcp" >>"$DEBUG_LOG" 2>&1 || true
    ufw reload >>"$DEBUG_LOG" 2>&1 || true
  fi
}

remove_firewall_port() {
  local port="$1"

  while iptables -C INPUT -p tcp --dport "$port" -j ACCEPT >/dev/null 2>&1; do
    iptables -D INPUT -p tcp --dport "$port" -j ACCEPT >>"$DEBUG_LOG" 2>&1 || break
  done

  if command -v ufw >/dev/null 2>&1; then
    ufw delete allow "${port}/tcp" >>"$DEBUG_LOG" 2>&1 || true
    ufw reload >>"$DEBUG_LOG" 2>&1 || true
  fi
}

write_meta() {
  cat > "$META_FILE" <<EOF
UPDATED_AT=$(date '+%F %T')
PORTS=$(tr '\n' ' ' < "$PORTS_FILE")
EOF
}

rebuild_squid_config() {
  {
    while IFS= read -r port; do
      [[ -n "$port" ]] && echo "http_port ${port}"
    done < "$PORTS_FILE"

    cat <<'EOF'

acl all src 0.0.0.0/0
acl SSL_ports port 22
acl SSL_ports port 80
acl SSL_ports port 443
acl Safe_ports port 22
acl Safe_ports port 80
acl Safe_ports port 443
acl Safe_ports port 1025-65535
acl CONNECT method CONNECT

http_access allow CONNECT SSL_ports
http_access allow all

via off
forwarded_for delete
request_header_access Allow allow all
request_header_access Authorization allow all
request_header_access WWW-Authenticate allow all
request_header_access Proxy-Authorization allow all
request_header_access Proxy-Authenticate allow all
request_header_access Cache-Control allow all
request_header_access Content-Encoding allow all
request_header_access Content-Length allow all
request_header_access Content-Type allow all
request_header_access Date allow all
request_header_access Expires allow all
request_header_access Host allow all
request_header_access If-Modified-Since allow all
request_header_access Last-Modified allow all
request_header_access Location allow all
request_header_access Pragma allow all
request_header_access Accept allow all
request_header_access Accept-Charset allow all
request_header_access Accept-Encoding allow all
request_header_access Accept-Language allow all
request_header_access Content-Language allow all
request_header_access Mime-Version allow all
request_header_access Retry-After allow all
request_header_access Title allow all
request_header_access Connection allow all
request_header_access Proxy-Connection allow all
request_header_access User-Agent allow all
request_header_access Cookie allow all
request_header_access All deny all

cache deny all
access_log /var/log/squid/access.log
cache_store_log none
cache_log /var/log/squid/cache.log
pid_filename /var/run/squid.pid
visible_hostname sshplus-autombot
EOF
  } > "$SQUID_CONF"
}

test_squid_config() {
  squid -k parse >>"$DEBUG_LOG" 2>&1
}

restart_squid() {
  systemctl enable squid >>"$DEBUG_LOG" 2>&1 || true
  systemctl restart squid >>"$DEBUG_LOG" 2>&1
}

show_ports_listening() {
  ss -lntp | grep squid || true
}

install_default_ports_if_empty() {
  if [[ ! -s "$PORTS_FILE" ]]; then
    echo "3128" > "$PORTS_FILE"
  fi
}

add_proxy_port() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      ADICIONAR PORTA HTTP"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  local port
  read -p "Porta HTTP do proxy [8080]: " port
  port="${port:-8080}"

  [[ ! "$port" =~ ^[0-9]+$ ]] && fail "Porta inválida." && return

  install_packages || { fail "Falha ao instalar dependências."; return; }
  ensure_base
  install_default_ports_if_empty

  add_port_to_list "$port"
  rebuild_squid_config

  test_squid_config || { fail "Erro na configuração do Squid."; return; }

  open_firewall_port "$port"

  restart_squid || {
    systemctl status squid -l --no-pager || true
    fail "Falha ao reiniciar o Squid."
    return
  }

  write_meta
  log_action "PROXYHTTPMULTI_ADD" "port=${port}"

  verde "Porta ${port} adicionada com sucesso."
  echo
  echo "Use no app:"
  echo "Modo        : SSH + PROXY HTTP"
  echo "Proxy Host  : vpn.autombot.com.br"
  echo "Proxy Porta : ${port}"
  echo "SSH Host    : vpn.autombot.com.br"
  echo "SSH Porta   : 22"
  echo "Payload     : vazio primeiro"
  echo
  show_ports_listening
  pause
}

remove_proxy_port_menu() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      REMOVER PORTA HTTP"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  local port
  read -p "Porta para remover: " port
  [[ -z "$port" ]] && return
  [[ ! "$port" =~ ^[0-9]+$ ]] && fail "Porta inválida." && return

  ensure_base
  remove_port_from_list "$port"
  rebuild_squid_config

  test_squid_config || { fail "Erro na configuração do Squid após remoção."; return; }

  remove_firewall_port "$port"

  restart_squid || {
    systemctl status squid -l --no-pager || true
    fail "Falha ao reiniciar o Squid."
    return
  }

  write_meta
  log_action "PROXYHTTPMULTI_REMOVE" "port=${port}"

  verde "Porta ${port} removida."
  pause
}

list_proxy_ports() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      PORTAS HTTP DO PROXY"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  ensure_base

  if [[ -s "$PORTS_FILE" ]]; then
    echo "[PORTAS CONFIGURADAS]"
    cat "$PORTS_FILE"
    echo
  else
    echo "Nenhuma porta configurada."
    echo
  fi

  echo "[PORTAS EM ESCUTA]"
  show_ports_listening
  echo
  pause
}

status_proxy_multi() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      STATUS PROXY HTTP MULTIPORTA"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  [[ -f "$META_FILE" ]] && echo "[METADADOS]" && cat "$META_FILE" && echo
  [[ -f "$SQUID_CONF" ]] && echo "[CONFIG]" && cat "$SQUID_CONF" && echo

  systemctl status squid -l --no-pager || true
  echo
  echo "[PORTAS EM ESCUTA]"
  show_ports_listening
  echo
  pause
}

restart_proxy_multi() {
  : > "$DEBUG_LOG"

  restart_squid || {
    systemctl status squid -l --no-pager || true
    fail "Falha ao reiniciar o Squid."
    return
  }

  log_action "PROXYHTTPMULTI_RESTART" "squid reiniciado"
  verde "Squid reiniciado."
  pause
}

tail_proxy_logs() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      LOGS DO PROXY HTTP"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "CTRL+C para sair"
  echo
  touch /var/log/squid/access.log
  tail -f /var/log/squid/access.log
}

require_root

while true; do
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "   GERENCIAR PROXY HTTP MULTIPORTA"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo " [1] Adicionar porta HTTP"
  echo " [2] Remover porta HTTP"
  echo " [3] Listar portas"
  echo " [4] Ver status"
  echo " [5] Reiniciar Squid"
  echo " [6] Ver logs access.log"
  echo " [0] Voltar"
  echo
  read -p "Escolha uma opção: " op

  case "$op" in
    1) add_proxy_port ;;
    2) remove_proxy_port_menu ;;
    3) list_proxy_ports ;;
    4) status_proxy_multi ;;
    5) restart_proxy_multi ;;
    6) tail_proxy_logs ;;
    0) exit 0 ;;
    *) echo "Opção inválida."; sleep 1 ;;
  esac
done