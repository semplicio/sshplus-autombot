#!/bin/bash

META_DIR="/etc/SSHPlus/xray-clientes"
XRAY_WS_CONF="/usr/local/etc/xray/config.json"
XRAY_GRPC_CONF="/usr/local/etc/xray/grpc-config.json"

mkdir -p "$META_DIR"

buscar_cliente_conf() {
  local conf="$1"
  local email="$2"

  python3 - "$conf" "$email" <<'PY'
import json
import sys
from pathlib import Path

conf = Path(sys.argv[1])
email = sys.argv[2]

if not conf.exists():
    sys.exit(1)

data = json.loads(conf.read_text())
if "inbounds" not in data or not data["inbounds"]:
    sys.exit(2)

inb = data["inbounds"][0]
proto = inb.get("protocol", "")
clients = inb.get("settings", {}).get("clients", [])

for c in clients:
    if c.get("email") == email:
        print(f"{proto}|{c.get('id','')}")
        sys.exit(0)

sys.exit(3)
PY
}

cadastrar_ou_atualizar_plano() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      CADASTRAR / ATUALIZAR PLANO"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  read -p "Email do cliente Xray: " client_email
  [[ -z "$client_email" ]] && echo "Email inválido." && read -p "Enter para voltar..." && return

  echo
  echo "Serviço:"
  echo " [1] Xray WS"
  echo " [2] Xray gRPC"
  echo
  read -p "Escolha: " srvop

  case "$srvop" in
    1)
      service_name="xray_ws"
      conf_file="$XRAY_WS_CONF"
      ;;
    2)
      service_name="xray_grpc"
      conf_file="$XRAY_GRPC_CONF"
      ;;
    *)
      echo "Serviço inválido."
      read -p "Enter para voltar..."
      return
      ;;
  esac

  client_data="$(buscar_cliente_conf "$conf_file" "$client_email" || true)"
  if [[ -z "$client_data" ]]; then
    echo "Cliente não encontrado no serviço selecionado."
    read -p "Enter para voltar..."
    return
  fi

  client_proto="$(echo "$client_data" | cut -d'|' -f1)"
  client_uuid="$(echo "$client_data" | cut -d'|' -f2)"

  read -p "Plano [mensal]: " client_plan
  client_plan="${client_plan:-mensal}"

  read -p "Dias de validade [30]: " client_days
  client_days="${client_days:-30}"

  if [[ ! "$client_days" =~ ^[0-9]+$ ]]; then
    echo "Quantidade de dias inválida."
    read -p "Enter para voltar..."
    return
  fi

  read -p "Observação [vazio para nenhuma]: " client_note

  expire_date="$(date -d "+${client_days} days" +%Y-%m-%d)"
  created_at="$(date +%Y-%m-%d\ %H:%M:%S)"

  cat > "${META_DIR}/${client_email}.conf" <<EOF
EMAIL=${client_email}
UUID=${client_uuid}
PROTO=${client_proto}
SERVICE=${service_name}
PLAN=${client_plan}
STATUS=active
CREATED_AT=${created_at}
EXPIRE_DATE=${expire_date}
NOTE=${client_note}
EOF

  /bin/loggerapi "XRAY_PLAN_SAVE" "email=${client_email} service=${service_name} plano=${client_plan} expira=${expire_date}"

  echo
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "Plano salvo com sucesso"
  echo "Cliente  : ${client_email}"
  echo "Serviço  : ${service_name}"
  echo "Plano    : ${client_plan}"
  echo "Validade : ${expire_date}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo
  read -p "Enter para voltar..."
}

listar_planos() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "                 PLANOS XRAY CADASTRADOS"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  found=0
  for f in "${META_DIR}"/*.conf; do
    [[ -f "$f" ]] || continue
    found=1

    email="$(grep '^EMAIL=' "$f" | cut -d= -f2-)"
    service="$(grep '^SERVICE=' "$f" | cut -d= -f2-)"
    plan="$(grep '^PLAN=' "$f" | cut -d= -f2-)"
    status="$(grep '^STATUS=' "$f" | cut -d= -f2-)"
    exp="$(grep '^EXPIRE_DATE=' "$f" | cut -d= -f2-)"

    printf "%-30s %-12s %-12s %-12s %-12s\n" "$email" "$service" "$plan" "$status" "$exp"
  done

  if [[ "$found" -eq 0 ]]; then
    echo "Nenhum plano cadastrado."
  fi

  echo
  read -p "Enter para voltar..."
}

ver_detalhes_plano() {
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "         DETALHES DO PLANO"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  read -p "Email do cliente: " client_email
  [[ -z "$client_email" ]] && echo "Email inválido." && read -p "Enter para voltar..." && return

  file="${META_DIR}/${client_email}.conf"
  if [[ ! -f "$file" ]]; then
    echo "Plano não encontrado."
    read -p "Enter para voltar..."
    return
  fi

  cat "$file"
  echo
  read -p "Enter para voltar..."
}

while true; do
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "      GESTÃO DE PLANOS XRAY"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo " [1] Cadastrar / Atualizar plano"
  echo " [2] Listar planos"
  echo " [3] Ver detalhes do plano"
  echo " [0] Voltar"
  echo
  read -p "Escolha uma opção: " op
  case "$op" in
    1) cadastrar_ou_atualizar_plano ;;
    2) listar_planos ;;
    3) ver_detalhes_plano ;;
    0) exit 0 ;;
    *) echo "Opção inválida."; sleep 1 ;;
  esac
done