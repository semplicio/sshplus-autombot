#!/bin/bash

clear
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "                         MONITOR SSH"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo

printf "%-20s %-10s %-50s\n" "USUARIO" "PID" "PROCESSO"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

data="$(ps -eo user=,pid=,cmd= | grep '[s]shd:' | grep -v root)"

if [[ -z "$data" ]]; then
  echo "Nenhuma sessão SSH ativa."
else
  echo "$data" | while read -r user pid cmd; do
    printf "%-20s %-10s %-50s\n" "$user" "$pid" "$cmd"
  done
fi

echo
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Sessões via who:"
echo

who 2>/dev/null || true

echo
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Total de processos sshd de usuários: $(ps -eo user=,cmd= | awk '$1!="root" && $0 ~ /sshd:/ {c++} END {print c+0}')"
echo
read -p "Enter para voltar..."
