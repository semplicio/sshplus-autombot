      7) clear; run_update ;;
      8) clear; system_status ;;
      9) clear; restart_services ;;
      0) exit 0 ;;
      *) vermelho "OpГ§ГЈo invГЎlida."; sleep 1 ;;
    esac
  done
}

main_menu
