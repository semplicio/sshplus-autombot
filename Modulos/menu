#!/bin/bash

INSTALL_DIR="/usr/local/lib/sshplus"
VERSION_FILE="${INSTALL_DIR}/versao"
EXP_FILE="/etc/SSHPlus/Exp"
IP_FILE="/etc/IP"

cor_padrao() { echo -e "\033[0m"; }
verde() { echo -e "\033[1;32m$1\033[0m"; }
amarelo() { echo -e "\033[1;33m$1\033[0m"; }
vermelho() { echo -e "\033[1;31m$1\033[0m"; }
azul() { echo -e "\033[1;34m$1\033[0m"; }

get_ip() {
  [[ -f "$IP_FILE" ]] && cat "$IP_FILE" || curl -4 -fsSL ifconfig.me 2>/dev/null || echo "0.0.0.0"
}

get_version() {
  [[ -f "$VERSION_FILE" ]] && head -n 1 "$VERSION_FILE" || echo "VERSAO: 0"
}

get_online_users() {
  ps -x | grep sshd | grep -v root | grep -v grep | wc -l
}

get_total_users() {
  awk -F: '$3>=1000 {print $1}' /etc/passwd | grep -v nobody | wc -l
}

get_expired_users() {
  [[ -f "$EXP_FILE" ]] && cat "$EXP_FILE" || echo "0"
}

show_header() {
  local ip version online total expired
  ip="$(get_ip)"
  version="$(get_version)"
  online="$(get_online_users)"
  total="$(get_total_users)"
  expired="$(get_expired_users)"

  clear
  echo -e "\033[0;35mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
  echo -e "\033[1;37m                 SSHPLUS AutomBot ARM              \033[0m"
  echo -e "\033[0;35mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
  echo -e "\033[1;33mIP:\033[0m $ip"
  echo -e "\033[1;33mVersГЈo:\033[0m $version"
  echo -e "\033[1;33mOnline SSH:\033[0m $online"
  echo -e "\033[1;33mUsuГЎrios:\033[0m $total"
  echo -e "\033[1;33mExpirados:\033[0m $expired"
  echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
}

show_options() {
  echo " [1] Ver status do sistema"
  echo " [2] Verificar atualizaГ§ГЈo"
  echo " [3] Atualizar script"
  echo " [4] Reiniciar serviГ§os bГЎsicos"
  echo " [5] Sair"
  echo
}

system_status() {
  echo -e "\033[1;32mSistema:\033[0m $(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '"')"
  echo -e "\033[1;32mKernel:\033[0m $(uname -r)"
  echo -e "\033[1;32mArquitetura:\033[0m $(uname -m)"
  echo -e "\033[1;32mMemГіria:\033[0m $(free -h | awk '/Mem:/ {print $3 " / " $2}')"
  echo -e "\033[1;32mDisco:\033[0m $(df -h / | awk 'NR==2 {print $3 " / " $2 " (" $5 ")"}')"
  echo
  read -p "Enter para voltar..."
}

check_update() {
  if command -v verifatt >/dev/null 2>&1; then
    result="$(verifatt 2>/dev/null || true)"
    if echo "$result" | grep -q "ATUALIZACAO_DISPONIVEL"; then
      verde "AtualizaГ§ГЈo encontrada."
    else
      amarelo "Nenhuma atualizaГ§ГЈo encontrada."
    fi
  else
    vermelho "Comando verifatt nГЈo encontrado."
  fi
  echo
  read -p "Enter para voltar..."
}

run_update() {
  if command -v attscript >/dev/null 2>&1; then
    bash /bin/attscript
  else
    vermelho "Comando attscript nГЈo encontrado."
    echo
    read -p "Enter para voltar..."
  fi
}

restart_services() {
  systemctl restart ssh >/dev/null 2>&1 || service ssh restart >/dev/null 2>&1 || true
  systemctl restart cron >/dev/null 2>&1 || service cron restart >/dev/null 2>&1 || true
  verde "ServiГ§os bГЎsicos reiniciados."
  echo
  read -p "Enter para voltar..."
}

main_menu() {
  while true; do
    show_header
    show_options
    read -p "Escolha uma opГ§ГЈo: " opcao
    case "$opcao" in
      1) clear; system_status ;;
      2) clear; check_update ;;
      3) clear; run_update ;;
      4) clear; restart_services ;;
      5) exit 0 ;;
      *) vermelho "OpГ§ГЈo invГЎlida."; sleep 1 ;;
    esac
  done
}

main_menu
