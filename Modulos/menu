#!/bin/bash

INSTALL_DIR="/usr/local/lib/sshplus"
VERSION_FILE="${INSTALL_DIR}/versao"
EXP_FILE="/etc/SSHPlus/Exp"
LIMIT_DIR="/etc/SSHPlus/limites"
IP_FILE="/etc/IP"

verde() { echo -e "\033[1;32m$1\033[0m"; }
amarelo() { echo -e "\033[1;33m$1\033[0m"; }
vermelho() { echo -e "\033[1;31m$1\033[0m"; }

get_ip() {
  [[ -f "$IP_FILE" ]] && cat "$IP_FILE" || curl -4 -fsSL ifconfig.me 2>/dev/null || echo "0.0.0.0"
}

get_version() {
  [[ -f "$VERSION_FILE" ]] && head -n 1 "$VERSION_FILE" || echo "VERSAO: 0"
}

get_online_users() {
  ps -ef | grep '[s]shd:' | grep -v root | wc -l
}

get_total_users() {
  awk -F: '$3>=1000 && $1!="nobody" {print $1}' /etc/passwd | wc -l
}

get_expired_users() {
  local count=0
  while IFS=: read -r user _ uid _ _ _ _; do
    [[ "$uid" -lt 1000 ]] && continue
    [[ "$user" == "nobody" ]] && continue

    exp="$(chage -l "$user" 2>/dev/null | awk -F': ' '/Account expires/ {print $2}')"
    if [[ -n "$exp" && "$exp" != "never" && "$exp" != "jamais" && "$exp" != "Nunca" ]]; then
      exp_epoch="$(date -d "$exp" +%s 2>/dev/null || echo 0)"
      now_epoch="$(date +%s)"
      if [[ "$exp_epoch" -gt 0 && "$exp_epoch" -lt "$now_epoch" ]]; then
        count=$((count + 1))
      fi
    fi
  done < /etc/passwd

  echo "$count"
}

