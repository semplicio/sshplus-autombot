system_status() {
  echo -e "\033[1;32mSistema:\033[0m $(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '"')"
  echo -e "\033[1;32mKernel:\033[0m $(uname -r)"
  echo -e "\033[1;32mArquitetura:\033[0m $(uname -m)"
  echo -e "\033[1;32mMemória:\033[0m $(free -h | awk '/Mem:/ {print $3 " / " $2}')"
  echo -e "\033[1;32mDisco:\033[0m $(df -h / | awk 'NR==2 {print $3 " / " $2 " (" $5 ")"}')"
  echo
  read -p "Enter para voltar..."
}

check_update() {
  if command -v verifatt >/dev/null 2>&1; then
    result="$(verifatt 2>/dev/null || true)"
    if echo "$result" | grep -q "ATUALIZACAO_DISPONIVEL"; then
      verde "Atualização encontrada."
    else
      amarelo "Nenhuma atualização encontrada."
    fi
  else
    vermelho "Comando verifatt não encontrado."
  fi
  echo
  read -p "Enter para voltar..."
}

run_update() {
  if command -v attscript >/dev/null 2>&1; then
    bash /bin/attscript
  else
    vermelho "Comando attscript não encontrado."
    echo
    read -p "Enter para voltar..."
  fi
}

restart_services() {
  systemctl restart ssh >/dev/null 2>&1 || service ssh restart >/dev/null 2>&1 || true
  systemctl restart cron >/dev/null 2>&1 || service cron restart >/dev/null 2>&1 || true
  verde "Serviços básicos reiniciados."
  echo
  read -p "Enter para voltar..."
}

run_module() {
  local module="$1"
  if [[ -x "/bin/$module" ]]; then
    "/bin/$module"
  else
    vermelho "Módulo /bin/$module não encontrado."
    echo
    read -p "Enter para voltar..."
  fi
}

validate_modules() {
  local missing=0
  local mods=(
    criarusuario
    alterarsenha
    alterarlimite
    remover
    sshmonitor
    sessoesusuario
    listarusuarios
    verifatt
    attscript
    verifilimite
