    exportarinfo
    jsonstatus
    exportarjson
    installws
    installxray
    installopenvpn
    installnginxws
    installxraygrpc
    installcamuflagem
    painelconexoes
    reiniciarservicos
    xrayaddcliente
    xraylistarclientes
    xrayremovercliente
    xraygerarconfig
    xrayexportarcliente
    gerarpacotecliente
    exportarpacotecliente
    xrayplanos
    xrayexpirar
    payloadpaths
    payloadviewer
    payloadexport
    payloadexportfile
    payloadprofiles
    payloadprofileexport
    installtls
    tlsrenew
  )

  for mod in "${mods[@]}"; do
    if [[ ! -x "/bin/$mod" ]]; then
      echo "Módulo ausente: /bin/$mod"
      missing=1
    fi
  done

  if [[ "$missing" -eq 1 ]]; then
    echo
    read -p "Alguns módulos estão ausentes. Pressione Enter para continuar..."
  fi
}

