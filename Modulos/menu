  echo " [3] Alterar limite"
  echo " [4] Remover usuГЎrio"
  echo " [5] Monitor SSH"
  echo " [6] Verificar atualizaГ§ГЈo"
  echo " [7] Atualizar script"
  echo " [8] Status do sistema"
