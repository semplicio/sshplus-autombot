  branco " $titulo"
  azul "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

system_status() {
  show_subheader "STATUS DO SISTEMA"
  echo -e "\033[1;32mSistema:\033[0m $(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '"')"
  echo -e "\033[1;32mKernel:\033[0m $(uname -r)"
  echo -e "\033[1;32mArquitetura:\033[0m $(uname -m)"
  echo -e "\033[1;32mMemória:\033[0m $(free -h | awk '/Mem:/ {print $3 " / " $2}')"
  echo -e "\033[1;32mDisco:\033[0m $(df -h / | awk 'NR==2 {print $3 " / " $2 " (" $5 ")"}')"
  pause
}

check_update() {
  show_subheader "VERIFICAR ATUALIZAÇÃO"
  if command -v verifatt >/dev/null 2>&1; then
    result="$(verifatt 2>/dev/null || true)"
    if echo "$result" | grep -q "ATUALIZACAO_DISPONIVEL"; then
      verde "Atualização encontrada."
    else
      amarelo "Nenhuma atualização encontrada."
    fi
  else
    vermelho "Comando verifatt não encontrado."
  fi
  pause
}

run_update() {
  if command -v attscript >/dev/null 2>&1; then
    bash /bin/attscript
  else
    show_subheader "ATUALIZAR SCRIPT"
    vermelho "Comando attscript não encontrado."
    pause
  fi
}

restart_basic_services() {
  show_subheader "REINICIAR SERVIÇOS BÁSICOS"
  systemctl restart ssh >/dev/null 2>&1 || service ssh restart >/dev/null 2>&1 || true
  systemctl restart cron >/dev/null 2>&1 || service cron restart >/dev/null 2>&1 || true
  verde "Serviços básicos reiniciados."
  pause
}

run_module() {
  local module="$1"
  if [[ -x "/bin/$module" ]]; then
    "/bin/$module"
  else
    vermelho "Módulo /bin/$module não encontrado."
    pause
  fi
}

validate_modules() {
  local missing=0
  local mods=(
    criarusuario
    alterarsenha
    alterarlimite
    remover
    sshmonitor
    sessoesusuario
    listarusuarios
    verifatt
    attscript
    verifilimite
    killexcesso
    expcheck
    loggerapi
    verlogs
    backupbase
    restaurarbase
    dashboardinfo
    exportarinfo
    jsonstatus
    exportarjson
    installws
    installxray
    installopenvpn
    installnginxws
    installxraygrpc
    installcamuflagem
    painelconexoes
    reiniciarservicos
    xrayaddcliente
    xraylistarclientes
    xrayremovercliente
    xraygerarconfig
    xrayexportarcliente
    gerarpacotecliente
    exportarpacotecliente
    xrayplanos
    xrayexpirar
    payloadpaths
    payloadviewer
    payloadexport
    payloadexportfile
    payloadprofiles
    payloadprofileexport
    installtls
    tlsrenew
    installsockshttp
    sockshttpstatus
    conexaomonitor
    testeconexao
    proxyportas
    proxyhttpmulti
  )

  for mod in "${mods[@]}"; do
    if [[ ! -x "/bin/$mod" ]]; then
      echo "Módulo ausente: /bin/$mod"
      missing=1
    fi
  done

  if [[ "$missing" -eq 1 ]]; then
    echo
    read -p "Alguns módulos estão ausentes. Pressione Enter para continuar..." _
  fi
}

